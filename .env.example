# Copy this file to `.env` and fill values.
# Streamlit Cloud users can set these in `.streamlit/secrets.toml` instead.

# Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Tavily API key (free tier works)
TAVILY_API_KEY=tvly-...

# SEC EDGAR requires a real identifying user-agent string
# Format: <Project/Org Name> <contact email>
SEC_USER_AGENT=Quorum Project you@example.com

# Optional runtime overrides
MODEL_NAME=claude-sonnet-4-5-20250929
MAX_TOKENS=4096
TEMPERATURE=0.3
